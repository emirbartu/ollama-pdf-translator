# --- Backend 1: Local Ollama (default — no key needed) ---
# Just install Ollama (https://ollama.com/), then:
#   ollama pull llama3.2
# Nothing to configure. If your server runs elsewhere, point to it:
# OPENAI_BASE_URL=http://localhost:11434/v1

# --- Backend 2: Any OpenAI-compatible API (OpenAI, OpenRouter, LM Studio, Ollama, ...) ---
# OPENAI_BASE_URL=https://api.openai.com/v1
# OPENAI_API_KEY=

# Model to use (CLI default and web demo server fallback). Match your backend, e.g.:
#   llama3.2 (local) · gpt-4o-mini (OpenAI) · any model your endpoint serves
# LLM_MODEL=llama3.2
